{
  "id": "soak_railway",
  "label": "Railway Soak",
  "description": "Scheduled long-running Railway lane for drift, recovery, compaction, and growth checks against the same persisted volume.",
  "default_records": 10000,
  "record_counts": [10000, 100000],
  "dataset": "generated_hybrid",
  "scenarios": ["http_falsification", "search_rag_6"],
  "surfaces": ["http_direct"],
  "adapters": ["http"],
  "controls": ["tracedb", "postgres", "pgvector"],
  "blocking_rules": {
    "correctness": true,
    "durability": true,
    "tenant_isolation": true,
    "tombstones": true,
    "snapshot_restore": true,
    "hard_failures": true,
    "require_external_controls": false,
    "performance_regression_policy": "rolling_regression_blocking"
  },
  "railway": {
    "required": true,
    "services": ["tracedb", "postgres", "pgvector"],
    "volume_required": true,
    "backup_required": true,
    "restart_required": true
  },
  "unsupported_coverage": {
    "sql_compatibility": "unsupported",
    "graphql_mutations": "unsupported",
    "graphql_subscriptions": "unsupported",
    "sql_postgres_wire_protocol": "unsupported"
  }
}
