{
  "id": "manual_1m",
  "label": "Manual 1m",
  "description": "Explicit opt-in scale lane for cliff discovery; never part of default push or release automation.",
  "default_records": 1000000,
  "record_counts": [1000000],
  "dataset": "generated_hybrid",
  "scenarios": ["http_falsification", "search_rag_6"],
  "surfaces": ["http_direct"],
  "adapters": ["http"],
  "controls": ["tracedb", "pgvector", "qdrant", "opensearch"],
  "blocking_rules": {
    "correctness": true,
    "hard_failures": true,
    "require_external_controls": true,
    "performance_regression_policy": "analysis_only"
  },
  "railway": {
    "required": false,
    "services": ["tracedb"]
  },
  "unsupported_coverage": {
    "sql_compatibility": "unsupported",
    "graphql_mutations": "unsupported",
    "graphql_subscriptions": "unsupported",
    "sql_postgres_wire_protocol": "unsupported"
  }
}
