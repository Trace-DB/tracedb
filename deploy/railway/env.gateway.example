TRACEDB_ENV=railway-lab
TRACEDB_LOG_LEVEL=info
TRACEDB_REGION=railway
TRACEDB_SERVICE_MODE=gateway
PORT=8080

# Public gateway ingress. Set the token as a Railway secret, not in git.
TRACEDB_REQUIRE_API_KEY=true
TRACEDB_API_TOKEN=replace-with-railway-secret

# Private engine routing.
TRACEDB_ENGINE_URL=http://tracedb-engine.railway.internal:8080
TRACEDB_ENGINE_INTERNAL_TOKEN=replace-with-shared-railway-secret

# Planned/optional control-plane dependencies for hosted-lab experiments.
# Leave unset unless the gateway path being tested has catalog/queue support wired.
TRACEDB_CATALOG_URL=
TRACEDB_REDIS_URL=
TRACEDB_RATE_LIMIT_ENABLED=false
