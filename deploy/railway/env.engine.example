TRACEDB_ENV=railway-lab
TRACEDB_LOG_LEVEL=info
TRACEDB_REGION=railway
TRACEDB_SERVICE_MODE=engine
PORT=8080

# Engine must be private for hosted-alpha ingress. Temporary public exposure is
# diagnostic-only for benchmark or disk validation runs.
TRACEDB_DATA_DIR=/data/tracedb
TRACEDB_SINGLE_WRITER=true
TRACEDB_ENGINE_INTERNAL_TOKEN=replace-with-shared-railway-secret

# Planned/optional snapshot/export bucket wiring. Do not use bucket storage for hot WAL.
# Leave S3 values unset unless snapshot/export support is explicitly being tested.
TRACEDB_SNAPSHOT_BUCKET=
TRACEDB_S3_ENDPOINT=
TRACEDB_S3_REGION=
TRACEDB_S3_ACCESS_KEY_ID=
TRACEDB_S3_SECRET_ACCESS_KEY=
