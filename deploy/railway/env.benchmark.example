TRACEDB_ENV=railway-lab
TRACEDB_LOG_LEVEL=info
TRACEDB_REGION=railway
TRACEDB_SERVICE_MODE=bench

# Benchmark runner target. Prefer gateway ingress. Direct engine URLs are
# diagnostic-only and must not be treated as hosted-alpha public ingress.
TRACEDB_HTTP_URL=https://tracedb-gateway.example.up.railway.app
RAILWAY_TRACEDB_URL=https://tracedb-gateway.example.up.railway.app
TRACEDB_HTTP_BEARER_TOKEN=replace-with-local-or-ci-secret

# Optional external controls.
BENCH_POSTGRES_DSN=
BENCH_PGVECTOR_DSN=
BENCH_MONGO_URI=
BENCH_QDRANT_URL=
BENCH_OPENSEARCH_URL=
