TRACEDB_ENV=production
TRACEDB_LOG_LEVEL=info
TRACEDB_REGION=railway
TRACEDB_DEFAULT_BRANCH=main
PORT=8080
# shared gateway/engine/worker private engine auth secret
TRACEDB_ENGINE_INTERNAL_TOKEN=replace-with-railway-shared-secret

# gateway
TRACEDB_SERVICE_MODE=gateway
TRACEDB_ENGINE_URL=http://tracedb-engine.railway.internal:8080
TRACEDB_PUBLIC_API=true
TRACEDB_REQUIRE_API_KEY=true
TRACEDB_RATE_LIMIT_ENABLED=true
TRACEDB_CATALOG_URL=postgres://postgres-catalog
TRACEDB_REDIS_URL=redis://redis-queue

# engine
TRACEDB_DATA_DIR=/data/tracedb
TRACEDB_SINGLE_WRITER=true
TRACEDB_SNAPSHOT_BUCKET=tracedb-bucket
TRACEDB_S3_ENDPOINT=
TRACEDB_S3_REGION=
TRACEDB_S3_ACCESS_KEY_ID=
TRACEDB_S3_SECRET_ACCESS_KEY=

# worker
TRACEDB_WORKER_ENGINE_URL=http://tracedb-engine.railway.internal:8080
