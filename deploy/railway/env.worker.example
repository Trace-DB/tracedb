TRACEDB_ENV=railway-lab
TRACEDB_LOG_LEVEL=info
TRACEDB_REGION=railway
TRACEDB_SERVICE_MODE=worker
PORT=8080

# Worker is private. It mutates state only through the internal engine API.
TRACEDB_WORKER_ENGINE_URL=http://tracedb-engine.railway.internal:8080
TRACEDB_ENGINE_INTERNAL_TOKEN=replace-with-shared-railway-secret
TRACEDB_REDIS_URL=redis://redis-queue
