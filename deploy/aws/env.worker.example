# TraceDB AWS worker environment example.
#
# WARNING: placeholder values only. Do not commit real secrets. Workers are
# private services and should mutate state only through the engine API.

TRACEDB_ENV=aws-alpha
TRACEDB_REGION=us-east-1
TRACEDB_LOG_LEVEL=info
TRACEDB_LOG_FORMAT=json
TRACEDB_SERVICE_MODE=worker
TRACEDB_BIND=0.0.0.0:8080

TRACEDB_ENGINE_URL=http://tracedb-engine:8080
TRACEDB_WORKER_ENGINE_URL=http://tracedb-engine:8080
TRACEDB_ENGINE_INTERNAL_TOKEN=replace-with-shared-engine-token-secret

# Optional private queue/bucket wiring for worker experiments.
TRACEDB_REDIS_URL=
TRACEDB_QUEUE_URL=
TRACEDB_SNAPSHOT_BUCKET=tracedb-aws-alpha-evidence
TRACEDB_S3_REGION=us-east-1
TRACEDB_S3_ENDPOINT=
