# TraceDB AWS engine environment example.
#
# WARNING: placeholder values only. Do not commit real secrets. For real hosts,
# inject these values from AWS Secrets Manager, SSM Parameter Store, or a local
# root-readable env file outside git.

TRACEDB_ENV=aws-alpha
TRACEDB_REGION=us-east-1
TRACEDB_LOG_LEVEL=info
TRACEDB_LOG_FORMAT=json
TRACEDB_SERVICE_MODE=engine
TRACEDB_BIND=0.0.0.0:8080
TRACEDB_DATA_DIR=/data/tracedb
TRACEDB_SINGLE_WRITER=true

# Shared private token used by gateway/worker when calling engine APIs.
TRACEDB_ENGINE_INTERNAL_TOKEN=replace-with-secret-from-ssm-or-secrets-manager

# Optional evidence/snapshot bucket wiring. Do not use S3 as hot WAL or active
# mutable index state.
TRACEDB_SNAPSHOT_BUCKET=tracedb-aws-alpha-evidence
TRACEDB_S3_REGION=us-east-1
TRACEDB_S3_ENDPOINT=
TRACEDB_S3_ACCESS_KEY_ID=
TRACEDB_S3_SECRET_ACCESS_KEY=
