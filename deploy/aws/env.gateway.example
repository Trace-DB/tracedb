# TraceDB AWS gateway environment example.
#
# WARNING: placeholder values only. Do not commit real secrets. Set production
# values through AWS Secrets Manager, SSM Parameter Store, or your deployment
# system.

TRACEDB_ENV=aws-alpha
TRACEDB_REGION=us-east-1
TRACEDB_LOG_LEVEL=info
TRACEDB_LOG_FORMAT=json
TRACEDB_SERVICE_MODE=gateway
TRACEDB_BIND=0.0.0.0:8080

# Public API token for gateway ingress. Keep this long, random, and secret.
TRACEDB_REQUIRE_API_KEY=true
TRACEDB_API_TOKEN=replace-with-public-api-token-secret

# Private engine routing. In docker compose this service name resolves on the
# private compose network; for hybrid Railway gateway deployments use the EC2/VPC
# private address or a private AWS load balancer endpoint instead.
TRACEDB_ENGINE_URL=http://tracedb-engine:8080
TRACEDB_ENGINE_INTERNAL_TOKEN=replace-with-shared-engine-token-secret

# Optional control-plane dependencies for hosted-alpha experiments.
TRACEDB_CATALOG_URL=
TRACEDB_REDIS_URL=
TRACEDB_RATE_LIMIT_ENABLED=true
